# --- Database -------------------------------------------------------------
# Use a local Postgres, or a hosted one (Neon / Supabase). Just paste the URL.
DATABASE_URL=postgresql://user:password@localhost:5432/bgv_db

# --- Auth -----------------------------------------------------------------
# Generate a long random string. Anything that signs JWTs in production
# should NOT be the literal value below.
JWT_SECRET=replace_me_with_a_long_random_secret_string

# --- Server ---------------------------------------------------------------
# Note: macOS uses port 5000 for AirPlay Receiver / ControlCenter, so we
# default to 5050 here. Any free port works.
PORT=5050
NODE_ENV=development

# The frontend dev origin. CORS will only allow this origin in dev.
FRONTEND_ORIGIN=http://localhost:5173

# --- Redis (optional) ----------------------------------------------------
# Used to back the rate limiter and cache dashboard stats. If unset, the
# app falls back to an in-memory rate limiter and skips caching.
#   brew install redis && brew services start redis     (macOS)
#   docker run -d -p 6379:6379 --name bgv-redis redis:7-alpine
REDIS_URL=redis://localhost:6379

# --- Mock verification APIs ----------------------------------------------
# These point at our own internal /mock-api routes so the verification
# service can talk to them over HTTP, just like a real third-party API.
AADHAAR_API_URL=http://localhost:5050/mock-api/aadhaar/verify
PAN_API_URL=http://localhost:5050/mock-api/pan/verify
